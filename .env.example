# NexusAI Intern Challenge - Environment Variables Template
# Copy this to .env and fill in your actual values

# ============================================================================
# API Provider Keys (choose at least ONE)
# ============================================================================

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/telecom

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
LOG_FILE=logs/nexusai.log

# ============================================================================
# Application Configuration
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode
DEBUG=true

# ============================================================================
# Notes
# ============================================================================
# 1. Create this file as .env (remove .example)
# 2. Never commit .env to version control (see .gitignore)
# 3. Keep .env.example in repo as template for other developers
# 4. Local overrides: create .env.local (also in .gitignore)
